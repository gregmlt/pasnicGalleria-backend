# Copier ce fichier en .env et remplir les valeurs réelles
# NE JAMAIS committer .env — ce fichier d'exemple seul est safe à committer

# MongoDB Atlas — connection string
DB_CONNECTION_STRING="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>"

# Cloudinary — URL d'authentification
CLOUDINARY_URL="cloudinary://<api_key>:<api_secret>@<cloud_name>"

# JWT — clé secrète de signature (générer avec : node -e "require('crypto').randomBytes(64).toString('hex')" )
JWT_SECRET="<votre_secret_jwt_64_caracteres>"

# CORS — origines autorisées séparées par virgule (prod uniquement)
# ALLOWED_ORIGINS="https://votre-domaine.com"
